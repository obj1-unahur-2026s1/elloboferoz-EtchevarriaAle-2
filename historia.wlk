import feroz.*
import caperucita.*

object historia {
    method contarHistoria(){
     feroz.correrHacia(bosque)
     feroz.conversarCon(caperucita)
     feroz.correrHacia(casaDeLaAbuela)
     feroz.comer(abuelita)
     feroz.disfrazarse(disfraz.abuelita())
     canasta.perderManzana()
     feroz.comer(caperucita)
     feroz.comer(canasta)
     feroz.comer(cazador)
     feroz.entrenar(30)
     feroz.sufrirCrisis()
    }
}

